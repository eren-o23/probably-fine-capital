# Fireworks AI
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# Kraken API (for private REST endpoints)
KRAKEN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
KRAKEN_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kraken CLI binary (use full path if not on $PATH)
KRAKEN_CLI_PATH=kraken

# News API (NewsAPI.org free tier)
NEWS_API_KEY=your_newsapi_key_here

# Fund parameters
FUND_NAME=Probably Fine Capital
STARTING_CASH=100000.0
PAPER_TRADING=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/fund.log

# Social posting (X / Twitter) — set true to enable, requires tweepy + X creds
X_ENABLED=false
